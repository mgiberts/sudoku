{
	"name": "sudoku",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"lint": "bunx biome lint .",
		"format": "bunx biome check --write --linter-enabled=false",
		"format:check": "bunx biome check",
		"format:all": "bun run format && bun run lint",
		"generate:expert": "bun scripts/generate-expert.ts --accept-clue-range --strategy remix --max-search-nodes 200",
		"generate:expert:probe": "bun scripts/generate-expert.ts --target 1 --accept-clue-range --strategy remix --timeout-ms 15000 --max-total-attempts 20 --max-search-nodes 200 --output /tmp/sudoku-expert-probe.ts --progress /tmp/sudoku-expert-probe.progress.json --reset-progress",
		"generate:expert:range-probe": "bun scripts/generate-expert.ts --target 1 --accept-clue-range --strategy remix --timeout-ms 15000 --max-total-attempts 20 --max-search-nodes 200 --output /tmp/sudoku-expert-range-probe.ts --progress /tmp/sudoku-expert-range-probe.progress.json --reset-progress",
		"generate:expert:smoke": "bun scripts/generate-expert.ts --difficulty easy --target 1 --timeout-ms 5000 --max-total-attempts 10 --output /tmp/sudoku-curated-smoke.ts --progress /tmp/sudoku-curated-smoke.progress.json --reset-progress --source script",
		"profile:expert": "bun scripts/profile-expert-generation.ts --attempts 20 --accept-clue-range --strategy remix --timeout-ms 15000 --max-search-nodes 200",
		"import:expert": "bun scripts/import-curated-expert.ts --input scripts/input/curated-expert.txt --require-count 100",
		"import:expert:check": "bun scripts/import-curated-expert.ts --input scripts/input/curated-expert.txt --require-count 100 --dry-run",
		"import:expert:partial": "bun scripts/import-curated-expert.ts --input scripts/input/curated-expert.txt --merge-existing --drop-mocks",
		"import:expert:smoke": "bun scripts/import-curated-expert-smoke.ts",
		"status:expert": "bun scripts/curated-expert-status.ts",
		"generate:starters": "bun scripts/generate-starters.ts",
		"generate:starters:smoke": "bun scripts/generate-starters.ts --count 1 --timeout-ms 10000 --max-total-attempts 20 --output /tmp/sudoku-starters-smoke.ts",
		"pr:check": "bun run format:all && bun run typecheck && bun run test",
		"test": "vitest run",
		"test:fast": "vitest run --coverage=false",
		"transform:expert": "bun scripts/transform-curated-expert.ts",
		"typecheck": "tsc --noEmit",
		"validate:games": "bun scripts/validate-game-data.ts",
		"validate:games:expert": "bun scripts/validate-game-data.ts --require-expert-count 100"
	},
	"dependencies": {
		"lucide-react": "^0.493.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.9.3",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.4",
		"jsdom": "^28.1.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vitest": "^4.0.18"
	}
}
